# forge-test-node — pre-cached Node.js test runner
# Pre-installs common React + Vite + testing dependencies so that
# pipeline test containers skip the slow npm-install step.

FROM node:20-alpine

WORKDIR /app

# Pre-install the most common dependencies that LLM-generated React/Vite
# projects will need.  When the test runner copies project files in and
# runs `npm install`, npm will see these are already present in the
# global node_modules cache and skip downloading them.

# 1. Create a skeleton package.json with the union of deps we expect.
RUN cat > /tmp/precache-package.json <<'EOF'
{
  "name": "forge-test-precache",
  "private": true,
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "vite": "^6.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "vitest": "^3.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/user-event": "^14.5.0",
    "jsdom": "^25.0.0",
    "jest": "^29.7.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0"
  }
}
EOF

# 2. Install into a global cache location.
#    We put them in /opt/forge-cache so they survive the WORKDIR wipe
#    when real project files are copied in.
RUN mkdir -p /opt/forge-cache && \
    cp /tmp/precache-package.json /opt/forge-cache/package.json && \
    cd /opt/forge-cache && \
    npm install --silent 2>/dev/null && \
    rm -f /tmp/precache-package.json

# 3. Set NODE_PATH so that `require()` / `import` can resolve from the
#    pre-cached location as a fallback when the project's own
#    node_modules doesn't have a package.
ENV NODE_PATH=/opt/forge-cache/node_modules

# 4. Default working dir for test execution.
WORKDIR /app

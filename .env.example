# Forge Environment Configuration

# Database Configuration
# REQUIRED — must be set before starting Forge
POSTGRES_USER=forge
POSTGRES_PASSWORD=<set_a_secure_password_here>
POSTGRES_DB=forge
POSTGRES_PORT=5432

# Service Ports
REDIS_PORT=6379
OLLAMA_PORT=11434
CHROMA_PORT=8000
GATEWAY_PORT=8080
FRONTEND_PORT=3000
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# Application Security
# REQUIRED — must be set before starting Forge
JWT_SECRET=<generate_a_secure_random_string_here_min_32_chars>

# REQUIRED — shared secret for gateway-to-service and service-to-service calls
INTERNAL_API_KEY=<generate_a_secure_random_string_here_min_32_chars>

# Docker service isolation
# Point forge-docker-svc at a restricted Docker API proxy or Docker-out-of-Docker daemon.
# Do not use or bind-mount the host /var/run/docker.sock.
DOCKER_HOST=tcp://docker-proxy:2375

# REQUIRED — Grafana admin password (anonymous auth is disabled)
GRAFANA_ADMIN_PASSWORD=<set_a_secure_password_here>

# Rate Limiting
RATE_LIMIT_PIPELINE=10
RATE_LIMIT_QUERY=100
# Comma-separated list of trusted reverse proxy IPs for X-Forwarded-For.
# Leave empty (default) to ignore X-Forwarded-For and use r.RemoteAddr.
TRUSTED_PROXIES=

# WebSocket Security
# Comma-separated list of allowed origins for WebSocket connections.
# Example: http://localhost:3000,https://app.forge.example.com
# Leave empty in production to deny all cross-origin WS connections.
# In DEV_MODE=true, localhost origins are always allowed.
WS_ALLOWED_ORIGINS=

# Ollama Configuration
OLLAMA_HOST=forge-ollama
# Points to host machine's Ollama (running locally, serving cloud models)
# host.docker.internal lets Docker containers reach your Mac's localhost
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Ollama models — swap these to any model available on your Ollama instance
# Cloud examples: qwen3:235b, qwen3:30b, llama3:70b, deepseek-coder-v2:236b
MODEL_REQUIREMENTS=qwen3.5:397b-cloud
MODEL_ARCHITECT=qwen3.5:397b-cloud
MODEL_CODEGEN=qwen3.5:397b-cloud
MODEL_REVIEW=qwen3.5:397b-cloud
MODEL_TEST=qwen3.5:397b-cloud
MODEL_CICD=qwen3.5:397b-cloud
MODEL_MONITOR=qwen3.5:397b-cloud
MODEL_INTENT=qwen3.5:397b-cloud

# nomic-embed-text is a proper embedding model; the chat models above cannot produce embeddings
MODEL_EMBEDDING=nomic-embed-text

# Forge Environment Configuration

# Database Configuration
POSTGRES_USER=forge
POSTGRES_PASSWORD=<your_postgres_password_here>
POSTGRES_DB=forge
POSTGRES_PORT=5432

# Service Ports
REDIS_PORT=6379
OLLAMA_PORT=11434
CHROMA_PORT=8000
GATEWAY_PORT=8080
GIT_SVC_PORT=8081
DOCKER_SVC_PORT=8082
ORCHESTRATOR_PORT=8090
FRONTEND_PORT=3000
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# Application Security
JWT_SECRET=<generate_a_secure_random_string_here>

# Rate Limiting
RATE_LIMIT_PIPELINE=10
RATE_LIMIT_QUERY=100

# Ollama Configuration
OLLAMA_HOST=forge-ollama
# Points to host machine's Ollama (running locally, serving cloud models)
# host.docker.internal lets Docker containers reach your Mac's localhost
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Ollama models — swap these to any model available on your Ollama instance
# Cloud examples: qwen3:235b, qwen3:30b, llama3:70b, deepseek-coder-v2:236b
MODEL_REQUIREMENTS=qwen3.5:397b-cloud
MODEL_ARCHITECT=qwen3.5:397b-cloud
MODEL_CODEGEN=qwen3.5:397b-cloud
MODEL_REVIEW=qwen3.5:397b-cloud
MODEL_TEST=qwen3.5:397b-cloud
MODEL_CICD=qwen3.5:397b-cloud
MODEL_MONITOR=qwen3.5:397b-cloud
MODEL_INTENT=qwen3.5:397b-cloud

# nomic-embed-text is a proper embedding model; the chat models above cannot produce embeddings
MODEL_EMBEDDING=nomic-embed-text
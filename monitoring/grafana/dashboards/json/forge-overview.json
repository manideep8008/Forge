{
  "dashboard": {
    "id": null,
    "uid": "forge-overview",
    "title": "Forge - Pipeline Overview",
    "tags": ["forge"],
    "timezone": "browser",
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "title": "Pipeline Duration",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(forge_pipeline_duration_seconds_bucket[5m]))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.50, rate(forge_pipeline_duration_seconds_bucket[5m]))",
            "legendFormat": "p50"
          }
        ]
      },
      {
        "id": 2,
        "title": "Agent Duration by Stage",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(forge_agent_duration_seconds_bucket[5m]))",
            "legendFormat": "{{agent_name}} p95"
          }
        ]
      },
      {
        "id": 3,
        "title": "Token Usage by Agent",
        "type": "bargauge",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "increase(forge_agent_tokens_total[1h])",
            "legendFormat": "{{agent_name}}"
          }
        ]
      },
      {
        "id": 4,
        "title": "Feedback Loop Iterations",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(forge_feedback_loop_iterations_bucket[5m]))",
            "legendFormat": "{{loop_type}} p95"
          }
        ]
      },
      {
        "id": 5,
        "title": "Gateway Request Rate",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "rate(forge_gateway_request_duration_count[5m])",
            "legendFormat": "{{method}} {{path}}"
          }
        ]
      },
      {
        "id": 6,
        "title": "Test Pass Rate",
        "type": "gauge",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "targets": [
          {
            "expr": "forge_test_pass_rate",
            "legendFormat": "{{pipeline_id}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 100,
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 50},
                {"color": "green", "value": 80}
              ]
            }
          }
        }
      }
    ]
  }
}
